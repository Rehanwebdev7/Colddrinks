PORT=8000
FRONTEND_URL=http://localhost:3000
FIREBASE_PROJECT_ID=noor-coldrinks

# JWT secret — REQUIRED. Server refuses to start without this.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_a_48_byte_random_hex

# JSON file fallback — set "1" on Render (ephemeral disk) to skip JSON writes,
# leaving Firestore as single source of truth. Local dev: "0" or unset.
JSON_FALLBACK_DISABLED=0

# CORS allowed origins (comma-separated). Production must include the frontend URL.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:5174

# Set either FIREBASE_SERVICE_ACCOUNT_JSON or FIREBASE_SERVICE_ACCOUNT_B64 in production
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_SERVICE_ACCOUNT_B64=base64-encoded-json

# Optional Google Drive production credentials
# DRIVE_CREDENTIALS_JSON={"type":"oauth_user",...}
# DRIVE_CREDENTIALS_B64=base64-encoded-json
# GOOGLE_DRIVE_MAIN_FOLDER_ID=your_google_drive_folder_id

# Option 1: SMTP service preset, e.g. Gmail
SMTP_SERVICE=gmail

# Option 2: direct SMTP host/port
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587

SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM="Royal Cold Drinks <your-email@example.com>"
